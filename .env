# ─── API de datos ────────────────────────────────────────────────
# API-Football (RapidAPI) — plan free: 100 req/día
# Obtén tu key en: https://rapidapi.com/api-sports/api/api-football
RAPIDAPI_KEY=pon_tu_key_aqui
RAPIDAPI_HOST=api-football-v1.p.rapidapi.com

# Fallback: football-data.org (10 req/min, gratis)
FOOTBALL_DATA_TOKEN=pon_tu_token_aqui

# ─── Base de datos ───────────────────────────────────────────────
DATABASE_PATH=./data/mundial2026.db

# ─── Telegram ────────────────────────────────────────────────────
# PASO 1: Crea un bot con @BotFather en Telegram
#   /newbot → dale nombre → copia el TOKEN
TELEGRAM_BOT_TOKEN= 8847766206:AAF5q_Gi1LtzEDxXE7hBeUv5CiqDYfyuVcQ

# PASO 2: Obtén tu Chat ID personal
#   Opción A: habla con @userinfobot → te da tu ID
#   Opción B: envía /start a tu bot y llama:
#   https://api.telegram.org/bot{TOKEN}/getUpdates
TELEGRAM_CHAT_ID=6019205367

# PASO 3 (opcional): ID de canal o grupo
#   Para canales empieza con -100...
#   Añade tu bot como admin con permisos de postear
TELEGRAM_CHANNEL_ID=

# Cuántas horas antes del partido enviar la previa (default: 2)
TELEGRAM_PREVIEW_HOURS=2

# Clave para proteger el endpoint /api/cron en producción
CRON_SECRET=genera_un_string_aleatorio_largo

# ─── Vercel (solo deploy) ────────────────────────────────────────
VERCEL_URL=
